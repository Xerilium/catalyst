{
  "traceability": {
    "default": { "code": "warning", "test": "warning" },
    "features": {
      "*-context": { "code": "disable", "test": "error" },
      "*-workflow": { "code": "disable", "test": "error" }
    },
    "scan": {
      "exclude": [
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/.git/**",
        "**/coverage/**",
        "**/fixtures/traceability/**"
      ]
    },
    "srcDirs": ["src/", "scripts/"]
  }
}
