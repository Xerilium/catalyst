{
  "traceability": {
    "default": { "code": "warning", "test": "warning" },
    "features": {
      "context-storage": { "code": "disable", "test": "error" },
      "*-context": { "code": "disable", "test": "error" },
      "*-workflow": { "code": "disable", "test": "error" }
    },
    "paths": {
      "code": ["src/", "scripts/"],
      "test": ["tests/", "**/*.test.*", "**/*.spec.*"],
      "exclude": [
        "**/node_modules/**",
        "**/dist/**",
        "**/build/**",
        "**/.git/**",
        "**/coverage/**",
        "**/fixtures/traceability/**"
      ]
    },
    "gitignore": true
  }
}
